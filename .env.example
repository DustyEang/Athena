# Athena environment configuration.
# Copy to `.env` and fill in what you have. EVERYTHING is optional —
# Athena runs in degraded mode (mock provider) with no keys at all.

# ---- Core ----
ATHENA_ENV=local                # local | server | hybrid
ATHENA_API_PORT=8765
ATHENA_DATA_DIR=                # default: <repo>/data

# ---- Local models (Ollama) ----
ATHENA_OLLAMA_URL=http://localhost:11434
ATHENA_OLLAMA_DEFAULT_MODEL=llama3.1

# ---- Premium provider: Fable 5 (Anthropic API) ----
# Leave blank to run without premium models. Never hardcode this in code.
ATHENA_FABLE5_API_KEY=
ATHENA_FABLE5_MODEL=claude-fable-5

# ---- Future providers (placeholders, unused in v1) ----
ATHENA_OPENAI_API_KEY=
ATHENA_GEMINI_API_KEY=

# ---- Future remote Athena server (server-assisted / hybrid mode) ----
ATHENA_SERVER_URL=
ATHENA_SERVER_TOKEN=

# ---- Voice (optional; app runs without these) ----
ATHENA_VOICE_ENABLED=false
ATHENA_ELEVENLABS_API_KEY=
