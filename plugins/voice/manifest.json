  "enabled": true,
  "placeholder": true,
  "permission": "read_only",
  "settings": {
    "wake_word": "Athena",
    "voice_personality": "calm, capable, slightly otherworldly",
    "audio_input_device": "default",
    "audio_output_device": "default"
  },
  "tools": [
    { "name": "start_listening", "description": "Begin push-to-talk capture.", "permission": "read_only", "input_schema": {}, "output_schema": {} },
    { "name": "stop_listening", "description": "Stop capture and transcribe.", "permission": "read_only", "input_schema": {}, "output_schema": {} },
    { "name": "speak", "description": "Speak text aloud via local TTS.", "permission": "read_only", "input_schema": { "type": "object", "properties": { "text": { "type": "string" } } }, "output_schema": {} },
    { "name": "wake_word_log", "description": "Wake-word reliability log (detections, false positives).", "permission": "read_only", "input_schema": {}, "output_schema": {} }
  ]
}
